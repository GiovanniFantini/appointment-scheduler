# =============================================================================
# APPOINTMENT SCHEDULER - CONSUMER APP ENVIRONMENT VARIABLES
# =============================================================================
# Copia questo file in .env e configura i valori appropriati per il tuo ambiente
# IMPORTANTE: NON committare il file .env nel repository!

# =============================================================================
# API CONFIGURATION
# =============================================================================
# URL dell'API backend
# Development: http://localhost:5000 (usando proxy Vite)
# Production: https://appointment-scheduler-api.azurewebsites.net (o il tuo dominio)
VITE_API_URL=http://localhost:5000

# Base path per le chiamate API (default: /api)
VITE_API_BASE_PATH=/api

# Timeout per le richieste API in millisecondi (default: 5000)
VITE_API_TIMEOUT=5000

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
# Abilitare credentials nelle richieste (default: false)
VITE_WITH_CREDENTIALS=false

# =============================================================================
# DEVELOPMENT SERVER CONFIGURATION
# =============================================================================
# Porta del development server Vite (default: 5173)
VITE_PORT=5173

# Proxy per le chiamate API in development
# Configurato in vite.config.ts
VITE_PROXY_TARGET=http://localhost:5000

# =============================================================================
# LOCALIZATION
# =============================================================================
# Locale dell'applicazione (default: it-IT)
VITE_LOCALE=it-IT

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Abilitare console di debug API (solo development)
VITE_ENABLE_API_DEBUG=true

# Abilitare logs dettagliati (solo development)
VITE_ENABLE_DEBUG_LOGS=false

# =============================================================================
# UI CONFIGURATION
# =============================================================================
# Numero minimo di persone per prenotazione
VITE_MIN_PEOPLE_PER_BOOKING=1

# Numero massimo di persone per prenotazione
VITE_MAX_PEOPLE_PER_BOOKING=100

# =============================================================================
# PRODUCTION SERVER CONFIGURATION (server.js)
# =============================================================================
# Porta del server Express in produzione (default: 8080)
PORT=8080

# URL dell'API backend in produzione
API_URL=https://appointment-scheduler-api.azurewebsites.net
