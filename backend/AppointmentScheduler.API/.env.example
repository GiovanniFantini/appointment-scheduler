# =============================================================================
# APPOINTMENT SCHEDULER - BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# Copia questo file in .env e configura i valori appropriati per il tuo ambiente
# IMPORTANTE: NON committare il file .env nel repository!

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Connection string per PostgreSQL
# Formato: Host=HOST;Port=PORT;Database=DB_NAME;Username=USER;Password=PASSWORD
POSTGRESQLCONNSTR_DefaultConnection=Host=localhost;Port=5432;Database=AppointmentScheduler;Username=postgres;Password=your_secure_password_here

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Chiave segreta per la firma dei token JWT (minimo 32 caratteri)
# CRITICO: Usa una chiave diversa e sicura per ogni ambiente!
# Genera una chiave sicura con: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-change-in-production

# Issuer del token JWT (chi emette il token)
JWT_ISSUER=AppointmentScheduler.API

# Audience del token JWT (chi può usare il token)
JWT_AUDIENCE=AppointmentScheduler.Client

# Durata del token JWT in minuti (default: 1440 = 24 ore)
JWT_EXPIRATION_MINUTES=1440

# =============================================================================
# ADMIN DEFAULT CREDENTIALS
# =============================================================================
# Credenziali dell'amministratore di default create al primo avvio
# CRITICO: Cambia questi valori in produzione!
ADMIN_DEFAULT_EMAIL=admin@admin.com
ADMIN_DEFAULT_PASSWORD=your_secure_admin_password_here
ADMIN_DEFAULT_FIRSTNAME=Admin
ADMIN_DEFAULT_LASTNAME=User

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Origins permessi per CORS (separati da virgola)
# Development example: http://localhost:5173,http://localhost:5174,http://localhost:5175
# Production example: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# URL su cui l'applicazione è in ascolto
# Development: http://localhost:5000;https://localhost:5001
# Production: configurato da Azure App Service
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001

# Ambiente di esecuzione (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Livello di log (Trace, Debug, Information, Warning, Error, Critical, None)
LOGGING_LOGLEVEL_DEFAULT=Information
LOGGING_LOGLEVEL_MICROSOFT_ASPNETCORE=Warning

# =============================================================================
# SWAGGER CONFIGURATION (solo per Development)
# =============================================================================
# Abilitare Swagger UI
ENABLE_SWAGGER=true

# =============================================================================
# HEALTH CHECKS CONFIGURATION
# =============================================================================
# Endpoint per health check
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_READY_PATH=/health/ready
HEALTH_CHECK_LIVE_PATH=/health/live

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# Timeout per le operazioni database (secondi)
DB_COMMAND_TIMEOUT=30

# Capacità massima default per i servizi
DEFAULT_MAX_CAPACITY=2147483647

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Lunghezza minima password
MIN_PASSWORD_LENGTH=6

# Numero massimo tentativi di login (future implementation)
MAX_LOGIN_ATTEMPTS=5

# Durata blocco account dopo troppi tentativi (minuti - future implementation)
ACCOUNT_LOCKOUT_MINUTES=15

# =============================================================================
# AZURE CONFIGURATION (per Production)
# =============================================================================
# Se deployato su Azure, queste variabili saranno configurate automaticamente
# APPLICATIONINSIGHTS_CONNECTION_STRING=your_app_insights_connection_string
# WEBSITE_SITE_NAME=your_azure_site_name
